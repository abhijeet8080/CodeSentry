generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model WebhookEvent {
  id           String   @id @default(cuid())
  deliveryId   String   @unique
  payload      Json
  createdAt    DateTime @default(now())
}

model ReviewJob {
  id           String   @id @default(cuid())
  deliveryId   String   @unique
  prNumber     Int
  repoFullName String

  status       String
  issueCount   Int?
  tokenUsed    Int?
  error        String?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}