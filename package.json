{
  "name": "bugbot",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:server": "npm -w @bugbot/server run dev",
    "dev:worker": "npm -w @bugbot/worker run dev",
    "build": "npm -w @bugbot/db run build && npm -w @bugbot/server run build && npm -w @bugbot/worker run build"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "ts-node-dev": "^2.0.0",
    "tsc-alias": "^1.8.10",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@octokit/rest": "^22.0.1",
    "dotenv": "^17.3.1",
    "openai": "^6.32.0",
    "pino": "^10.3.1",
    "pino-pretty": "^11.2.2",
    "zod": "^4.3.6"
  }
}
